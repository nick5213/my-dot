#!/usr/bin/env bash

### adb operate ###

# adb clear input text
function adb-clear() {
  adb shell input keyevent KEYCODE_MOVE_END
  adb shell input keyevent --longpress $(printf 'KEYCODE_DEL %.0s' {1..250})
}

function adb-restart() {
  echo "[adb-restart] finding adb server process..."

  for pid in $(pgrep -f "adb -L tcp:5037 fork-server server"); do
    echo "[adb-restart] killing adb server pid=$pid"
    kill -9 "$pid"
  done

  sleep 1

  echo "[adb-restart] starting adb server..."

  adb start-server >/dev/null 2>&1

  # 校验 adb 是否真正可用
  adb get-state >/dev/null 2>&1
  if [ $? -eq 0 ]; then
    echo "[adb-restart] adb ready"
    return 0
  fi

  echo "[adb-restart] retry starting adb..."

  adb start-server >/dev/null 2>&1
  adb get-state >/dev/null 2>&1
  if [ $? -eq 0 ]; then
    echo "[adb-restart] adb ready after retry"
    return 0
  fi

  echo "[adb-restart] adb failed after retry"
  return 1
}

#
# adb screen
#
# Arguments:
#  $1: png path: ~/output/xxx.png
#
function adb-screen() {
  local out_dir=$(dirname $1)
  local png_name=$(basename $1)
  local tmp_path="/data/local/tmp/$png_name"

  adb shell screencap -p $tmp_path
  adb pull $tmp_path $out_dir
  adb shell rm $tmp_path
}

### git operate ###

#
# git set global alias
#
# Arguments:
#  $1: alias
#  $2: command
#
function git-set-alias() {
  local alias=$1
  local cmd=$2
  git config --global alias.${alias} "${cmd}"
  git config --get-regexp alias.${alias}
}

#
# git clone sparse-checkout specified dir
#
# Arguments:
#  $1: url
#  $2: branch
#  ..: others file or dir
#
function git-clone-sparse() {
  local url=$1
  local branch=$2
  shift 2
  local params=$(echo "$@" | tr ' ' '\n')
  local name=$(basename -s .git $url)

  mkdir -p ${name}
  cd ${name} || return 1

  # init
  git init
  git remote add -f origin $url

  # enable sparsecheckout
  git config --local core.sparsecheckout true
  echo $params >> .git/info/sparse-checkout

  # checkout
  git checkout $branch

  cd -
}

# 
# upload to
#
# 用法：
#   up 本地文件(或目录) 远端主机 远端目录
#
# 示例：
#   up test.txt dev /home/root/
#   up mydir dev /home/root/
#
# 参数说明：
#   -a  : 归档模式（保留权限、时间等）
#   -v  : 显示详细日志
#   -z  : 传输时压缩
# 
function up() {
  if [ "$#" -ne 3 ]; then
    echo "用法: up 本地文件(或目录) 远端主机 远端目录"
    echo "示例: up test.txt dev /home/root/"
    echo "示例: up mydir dev /home/root/"
    return 1
  fi
  rsync -avz --progress "$1" "$2:$3"
}


# 
# 从远程机器下载文件/目录
#
# 用法：
#   down 远端主机 远端文件(或目录) 本地目录
#
# 示例：
#   down dev /home/root/test.txt ./
#   down dev /home/root/mydir ./
# 
function down() {
  if [ "$#" -ne 3 ]; then
    echo "用法: down 远端主机 远端文件(或目录) 本地目录"
    echo "示例: down dev /home/root/test.txt ./"
    echo "示例: down dev /home/root/mydir ./"
    return 1
  fi
  rsync -avz --progress "$1:$2" "$3"
}

# scp upload file
#
# 用法：
#   scpup 本地文件 远端主机 远端目录
#
# 示例：
#   scpup test.txt dev /home/root/
# 
function scpup() {
  if [ "$#" -ne 3 ]; then
    echo "用法: scpup 本地文件 远端主机 远端目录"
    echo "示例: scpup test.txt dev /home/root/"
    return 1
  fi
  scp "$1" "$2:$3"
}


# 
# scp upload dir
#
# 用法：
#   scpdir 本地目录 远端主机 远端目录
#
# 示例：
#   scpdir mydir dev /home/root/
# 
function scpdir() {
  if [ "$#" -ne 3 ]; then
    echo "用法: scpdir 本地目录 远端主机 远端目录"
    echo "示例: scpdir mydir dev /home/root/"
    return 1
  fi
  scp -r "$1" "$2:$3"
}


# 
# scp download file
#
# 用法：
#   scpdown 远端主机 远端文件 本地目录
#
# 示例：
#   scpdown dev /home/root/test.txt ./
# 
function scpdown() {
  if [ "$#" -ne 3 ]; then
    echo "用法: scpdown 远端主机 远端文件 本地目录"
    echo "示例: scpdown dev /home/root/test.txt ./"
    return 1
  fi
  scp "$1:$2" "$3"
}